# Force LF line endings for source files (matches warp-src convention)
*.rs       text eol=lf
*.toml     text eol=lf
*.md       text eol=lf
*.sh       text eol=lf
*.kt       text eol=lf
*.java     text eol=lf
*.gradle   text eol=lf
*.kts      text eol=lf
*.xml      text eol=lf
*.json     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf

# Binary files
*.so       binary
*.a        binary
*.apk      binary
*.aab      binary
*.jks      binary
*.keystore binary
*.png      binary
*.jpg      binary
*.webp     binary
*.gif      binary
*.ttf      binary
*.otf      binary

# Lockfiles — ensure LF, treat as text for diff
Cargo.lock text eol=lf
gradle.lockfile text eol=lf
