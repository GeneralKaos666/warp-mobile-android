<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug overlay: removes PTY_CONTROL permission from PtyBroadcastReceiver
  so `adb shell am broadcast` can reach it without the signature check.
  This file is ONLY merged into debug builds; release builds use main manifest only.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>
        <!-- tools:remove properly strips android:permission from merged debug manifest -->
        <receiver
            android:name=".PtyBroadcastReceiver"
            tools:remove="android:permission" />
        <!-- M2-S05: same pattern as PtyBroadcastReceiver — strip the
             PTY_CONTROL signature requirement so `adb shell am broadcast`
             can deliver CAPTURE_FRAME during device-driver tests. -->
        <receiver
            android:name=".CaptureFrameReceiver"
            tools:remove="android:permission" />
        <!-- M2-S10: same pattern as CaptureFrameReceiver — strip the
             PTY_CONTROL signature requirement so `adb shell am broadcast`
             can deliver IME_* simulation events during device-driver tests. -->
        <receiver
            android:name=".ImeSimulationReceiver"
            tools:remove="android:permission" />
        <!-- M2-S11: same pattern as ImeSimulationReceiver — strip the
             PTY_CONTROL signature requirement so `adb shell am broadcast`
             can deliver INPUT_* simulation events during device-driver tests. -->
        <receiver
            android:name=".TouchSimulationReceiver"
            tools:remove="android:permission" />
        <!-- M3-S05: same pattern — strip PTY_CONTROL so adb shell broadcasts
             can deliver TERM_INJECT_RAW for ANSI/DCS streaming-parser tests. -->
        <receiver
            android:name=".TerminalSimulationReceiver"
            tools:remove="android:permission" />
        <!-- v1-prep: same pattern — strip PTY_CONTROL so adb shell broadcasts
             can deliver GHOST_INJECT_SUGGESTION / GHOST_DISMISS for the
             AI ghost-strip end-to-end UX verification. -->
        <receiver
            android:name=".GhostSuggestSimulationReceiver"
            tools:remove="android:permission" />
        <!-- Export service in debug so `adb shell am start-foreground-service` works -->
        <service
            android:name=".WarpTerminalService"
            android:exported="true"
            tools:replace="android:exported" />
    </application>

</manifest>
