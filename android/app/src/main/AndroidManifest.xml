<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- M2-S04: require Vulkan 1.1 (matches MainActivity Vulkan setup;
         Adreno 6xx+ baseline per Plan Amendment 3 minSdk 31). -->
    <uses-feature android:name="android.hardware.vulkan.level" android:required="true" />
    <uses-feature android:name="android.hardware.vulkan.version"
        android:version="0x00401000"
        android:required="true" />

    <!-- Fix #3: signature-level permission so only our own signed APKs can control PTY -->
    <permission android:name="dev.warp.mobile.permission.PTY_CONTROL"
        android:protectionLevel="signature" />

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="dev.warp.mobile.permission.PTY_CONTROL" />
    <!-- M6-S02: HTTPS to api.anthropic.com for BYOK Test Connection +
         later ghost-text + agent task streaming. No background-network
         use; app must be foreground to make calls. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:label="@string/app_name"
        android:theme="@style/Theme.AppCompat"
        android:allowBackup="false">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- M6-S02: BYOK SettingsActivity. Launched via in-app navigation
             only (M6-S03 will add a settings icon entry-point in the
             AccessoryRow). M6 round-2 security review MEDIUM #4 + code-
             review LOW: exported=false because no other app has a
             legitimate reason to launch this Activity (no Intent extras
             accepted; only social-engineering vector if exported). For
             dev / debug `am start` access, use the explicit
             `-W -n` form which works regardless of exported status as
             long as the app is debuggable. -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="Warp AI · BYOK Settings" />

        <service
            android:name=".WarpTerminalService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="explanation: long-lived terminal session host" />
        </service>

        <!-- Fix #3: PTY_CONTROL permission applied; debug overlay (src/debug/) removes it for adb tests -->
        <receiver
            android:name=".PtyBroadcastReceiver"
            android:exported="true"
            android:permission="dev.warp.mobile.permission.PTY_CONTROL">
            <intent-filter>
                <action android:name="dev.warp.mobile.PTY_SPAWN" />
                <action android:name="dev.warp.mobile.PTY_WRITE" />
                <action android:name="dev.warp.mobile.PTY_RESIZE" />
                <action android:name="dev.warp.mobile.PTY_KILL" />
            </intent-filter>
        </receiver>

        <!-- M2-S05: frame-capture trigger receiver. Manifest-registered so
             `adb shell am broadcast` from shell UID can deliver to it
             (runtime-registered receivers don't reliably match on Android
             14+ when reached from another UID). The action is gated behind
             the same PTY_CONTROL signature permission as the PTY ops since
             this is a debug-only test hook — production capture path will
             go through warpui's renderer in M2-S08+. -->
        <receiver
            android:name=".CaptureFrameReceiver"
            android:exported="true"
            android:permission="dev.warp.mobile.permission.PTY_CONTROL">
            <intent-filter>
                <action android:name="dev.warp.mobile.CAPTURE_FRAME" />
                <!-- M2-S07: text-render variant (compose shaped glyphs onto
                     the captured RGBA before PNG encode). -->
                <action android:name="dev.warp.mobile.CAPTURE_FRAME_WITH_TEXT" />
            </intent-filter>
        </receiver>

        <!-- M2-S10: IME simulation receiver. `adb shell input text` does NOT
             route through InputConnection (it synthesizes raw KeyEvents at
             the dispatcher level), so to exercise the WarpInputConnection
             commitText / setComposingText / finishComposingText code path
             end-to-end without a custom IME on the device, the driver
             broadcasts these intents which the receiver forwards through
             the real BaseInputConnection subclass (or directly to JNI as
             fallback). Same PTY_CONTROL signature permission as the other
             debug-only test hooks. -->
        <receiver
            android:name=".ImeSimulationReceiver"
            android:exported="true"
            android:permission="dev.warp.mobile.permission.PTY_CONTROL">
            <intent-filter>
                <action android:name="dev.warp.mobile.IME_COMMIT_TEXT" />
                <action android:name="dev.warp.mobile.IME_SET_COMPOSING_TEXT" />
                <action android:name="dev.warp.mobile.IME_FINISH_COMPOSING_TEXT" />
                <action android:name="dev.warp.mobile.IME_RESET" />
                <action android:name="dev.warp.mobile.IME_TYPE_LATIN" />
            </intent-filter>
        </receiver>

        <!-- M2-S11: touch-input simulation receiver. `adb shell input tap` delivers
             real MotionEvents to WarpInputView.onTouchEvent. For swipe-velocity
             and long-press sub-tests where adb shell input's timing is non-
             deterministic, the driver broadcasts these intents which call the
             Rust JNI entry points directly (disclosed in result JSON).
             PTY_CONTROL signature permission protects release builds from arbitrary
             broadcast injection; the debug manifest overlay (src/debug/) strips it
             so `adb shell am broadcast` from uid=2000 can reach this receiver during
             device testing (same pattern as PtyBroadcastReceiver/ImeSimulationReceiver). -->
        <receiver
            android:name=".TouchSimulationReceiver"
            android:exported="true"
            android:permission="dev.warp.mobile.permission.PTY_CONTROL">
            <intent-filter>
                <action android:name="dev.warp.mobile.INPUT_TOUCH_DOWN" />
                <action android:name="dev.warp.mobile.INPUT_TOUCH_UP" />
                <action android:name="dev.warp.mobile.INPUT_TOUCH_CANCEL" />
                <action android:name="dev.warp.mobile.INPUT_TAP" />
                <action android:name="dev.warp.mobile.INPUT_LONG_PRESS" />
                <action android:name="dev.warp.mobile.INPUT_SCROLL" />
                <action android:name="dev.warp.mobile.INPUT_RESET" />
            </intent-filter>
        </receiver>

        <!-- M3-S05: terminal-input simulation receiver. Drives raw byte
             sequences (ESC[31m etc.) directly into the Rust streaming
             ANSI/DCS parser via NativeBridge.terminalInputBytes, sidestepping
             PTY-shell echo quirks. PTY pipeline (M3-S04) remains the
             production path; this receiver is device-side test instrumentation
             only. PTY_CONTROL permission as for the other simulation receivers;
             debug overlay strips it so adb shell broadcasts from uid=2000 can
             reach this receiver. -->
        <receiver
            android:name=".TerminalSimulationReceiver"
            android:exported="true"
            android:permission="dev.warp.mobile.permission.PTY_CONTROL">
            <intent-filter>
                <action android:name="dev.warp.mobile.TERM_INJECT_RAW" />
                <!-- M3-S07: dump current Vec<Block> as JSON to logcat for the
                     test-block-model.sh device driver to grep. -->
                <action android:name="dev.warp.mobile.TERM_BLOCKS_DUMP" />
                <!-- M3-S09: scrollback dump + scroll-offset broadcast control. -->
                <action android:name="dev.warp.mobile.TERM_SCROLLBACK_DUMP" />
                <action android:name="dev.warp.mobile.TERM_SET_SCROLL_OFFSET" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
