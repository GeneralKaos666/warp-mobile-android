<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.warpmobile.spike">

    <uses-feature android:name="android.hardware.vulkan.level" android:required="true" />
    <uses-feature android:name="android.hardware.vulkan.version"
        android:version="0x00401000"
        android:required="true" />

    <application
        android:label="VkSurfaceSpike"
        android:theme="@style/Theme.AppCompat.NoActionBar">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">
            <!-- configChanges scope: orientation|screenSize|screenLayout|keyboardHidden
                 prevents Activity recreation on rotation. MainActivity instance survives
                 and receives onConfigurationChanged, so waitingForRecovery state persists.
                 SCOPE LIMIT: this list does NOT cover all teardown paths. Process kill,
                 low-memory reaping, theme/locale change, multi-window resize, PiP entry,
                 and foldable posture changes still tear down the Activity. A production
                 renderer must handle full Activity recreate via savedInstanceState plus
                 swapchain rebuild. This spike measures Surface lifecycle only. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
