<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.warpmobile.spike">

    <uses-feature android:name="android.hardware.vulkan.level" android:required="true" />
    <uses-feature android:name="android.hardware.vulkan.version"
        android:version="0x00401000"
        android:required="true" />

    <application
        android:label="VkSurfaceSpike"
        android:theme="@style/Theme.AppCompat.NoActionBar">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">
            <!-- configChanges prevents Activity recreation on rotation.
                 The same MainActivity instance receives onConfigurationChanged instead,
                 so waitingForRecovery survives the orientation change.
                 A real renderer would need full swapchain recreate on configChanges;
                 for this spike, Surface lifecycle measurement is the goal. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
