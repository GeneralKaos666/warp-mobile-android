# ===== Rust =====
target/
Cargo.lock.bak
**/*.rs.bk
*.pdb

# ===== Android / Gradle =====
*.iml
*.apk
*.aab
*.ap_
*.dex
.gradle/
build/
captures/
.externalNativeBuild/
.cxx/
local.properties
proguard/
release/

# Cargo-ndk .so outputs copied into jniLibs at build time — never commit binaries
android/app/src/main/jniLibs/arm64-v8a/*.so

# Vulkan validation layer fetched by Gradle :app:fetchValidationLayer at build time — never commit binary
# (M2-S04 round-2, Codex blocker 4a). Source: KhronosGroup/Vulkan-ValidationLayers GitHub releases.
android/app/src/debug/jniLibs/arm64-v8a/*.so

# Android Studio
.idea/
*.iws
*.ipr

# Keystores (per-developer; never commit)
*.jks
*.keystore
*.p12
# v1-release prep: signing-config properties file (contains plaintext
# keystore password). Lives at android/keystore.properties when a
# developer wants to produce signed release APKs for GitHub Releases.
# F-Droid path doesn't use this — F-Droid signs from source itself.
keystore.properties

# ===== macOS =====
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# ===== Editors =====
.vscode/
*.swp
*.swo
*~
.nvimlog

# ===== direnv =====
.envrc.local
.direnv/

# ===== Project-specific =====

# Warp upstream fork — this is a separate git repo (warp-src/.git/).
# Do NOT track it inside this root repo. M2: convert to git submodule.
warp-src/

# Termux packages fork — separate git repo (termux-packages/.git/) for M4 runtime.
# Cloned from ImL1s/termux-packages on branch warp-mobile/main; same pattern as warp-src/.
termux-packages/

# Cargo cross-compile config — contains absolute machine paths (/Users/<name>/...).
# Track .cargo/config.toml.template instead; each dev runs tools/scripts/setup-cargo-config.sh
# to generate their local .cargo/config.toml from the template.
.cargo/config.toml

# OMC orchestration runtime state — local only
.omc/state/
.omc/sessions/
.omc/artifacts/
.omc/notepad.md
.omc/logs/
.omc/skills/

# Track these explicitly (negate for safety):
!.omc/plans/
!.omc/handoffs/
!.omc/m0-artifacts/

# OMX (other tooling state — entirely local)
.omx/

# Spike build outputs (per-spike target/)
spikes/*/target/
spikes/*/build/
spikes/*/.gradle/

# Test runner outputs (CSV/JSON per-device run results — keep one canonical, ignore re-runs)
spikes/*/results/
spikes/*/runs/

# Generated APKs go to dist/ if shipping
dist/

# Bootstrap zip output (M4-S03+) — produced by tools/scripts/build-bootstrap.sh,
# 30-50 MB binary artifact, never commit. CI uploads as workflow artifact;
# release builds publish to GitHub Releases.
_bootstrap-out/

# M4-S04 staged bootstrap inside APK assets — copied at gradle assemble time
# from _bootstrap-out/ via copyBootstrapZip + generateBootstrapVersion tasks.
# Never commit (43 MB binary). Reproduce locally via build-bootstrap.sh.
android/app/src/main/assets/warp/bootstrap/

# Tools cache
tools/.cache/

# Codex / Gemini ask transcripts (large, regenerable)
*-transcript.md
codex-*.md
gemini-*.md
!.omc/m0-artifacts/M0-*.md

# Working notes
SCRATCH.md
NOTES.local.md
TODO.local.md

# Env / secrets
.env
.env.local
.env.*.local
secrets/
*.secret
.omc/project-memory.json

# Claude Code per-project state
.claude/

# spikes/* compiled artifacts (rebuild locally per spike README)
spikes/vulkan-surface-recreate/android/app/src/main/jniLibs/
spikes/symlink-jnilibs/app/src/main/jniLibs/

# Defensive: never accidentally commit node_modules
node_modules/
